    {
      "type": "graph",
      "title": "HTTP Request Rate (requires /metrics instrumentation)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(http_requests_total[5m])" }]
    }
  ]
}
