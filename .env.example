# --- Application ---
APP_NAME=ThreatShield
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Development (SQLite, default if DATABASE_URL is unset):
DATABASE_URL=sqlite:///./threatshield.db
# Production (PostgreSQL) example:
# DATABASE_URL=postgresql://threatshield:threatshield@db:5432/threatshield

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:8000

# --- Email Alerts (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@threatshield.local
EMAIL_ALERTS_ENABLED=false

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false

# --- Slack Notifications ---
SLACK_WEBHOOK_URL=
SLACK_ALERTS_ENABLED=false

# --- Scheduler ---
SCAN_INTERVAL_HOURS=24
SCHEDULER_ENABLED=true

# --- AbuseIPDB (optional) ---
# Get a free API key at https://www.abuseipdb.com/register — leave blank to
# keep the AbuseIPDB tool disabled.
ABUSEIPDB_API_KEY=

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
